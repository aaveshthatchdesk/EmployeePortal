 @if(showAddEmployee)
{
    <AddEmployee 
        OnClose="CloseAddEmployeeForm"
        OnSaved="ReloadEmployees"/>
}

@code {

    private List<EmployeeDto> pagedEmployees = new();
    private List<EmployeeDto> employee;
    private EmployeesSummary employeesSummary=new();

    private int currentPage = 1;
    private int pageSize = 8;
    private int totalCount = 0;
    private string searchTerm = "";
    private int userId;
    private string role;
    private bool showAddEmployee=false;

    protected override async Task OnInitializedAsync()
    {
        var authState = await AuthStateProvider.GetAuthenticationStateAsync();
        var user=authState.User;
        Console.WriteLine(user.Identity.IsAuthenticated);
        Console.WriteLine(user.Identity.AuthenticationType);
        if (user.Identity?.IsAuthenticated == true)
        {
            userId = int.Parse(user.FindFirst(ClaimTypes.NameIdentifier)?.Value ?? "0");
            role = user.FindFirst(ClaimTypes.Role)?.Value;
        }

        Console.WriteLine(user.FindFirst(ClaimTypes.NameIdentifier)?.Value);
        await LoadSummary();
        await LoadEmployees();
    }
    public async Task LoadSummary()
    {
      employeesSummary= await _employeeService.DashboardSummary();
    }
    private void ShowAddEmployeeForm()
    {
        showAddEmployee = true;
    }

    private void CloseAddEmployeeForm()
    {
        showAddEmployee = false;
    }

    private async Task ReloadEmployees()
    {
        await LoadEmployees();
    }
    public async Task LoadEmployees()
    {
        var result = await _employeeService.GetEmployeesByUserRole(userId, role, currentPage, pageSize, searchTerm);
        pagedEmployees = result?.Items ?? new List<EmployeeDto>();
        totalCount = result?.TotalCount ?? 0;
    }

    private async Task GoToPage(int page)
    {
        currentPage = page;
        StateHasChanged();

        await LoadEmployees();
    }

    private int TotalPages => (int)Math.Ceiling((double)totalCount / pageSize);

    private async Task NextPage()
    {
        if (currentPage < TotalPages)
        {
            currentPage++;
            await LoadEmployees();
        }
    }

    private async Task PreviousPage()
    {
        if (currentPage > 1)
        {
            currentPage--;
            await LoadEmployees();
        }
    }
    List<int> GetVisiblePages()
    {
        int maxPagesToShow = 5;
        int start = Math.Max(1, currentPage - 2);
        int end = Math.Min(TotalPages, start + maxPagesToShow - 1);

        return Enumerable.Range(start, end - start + 1).ToList();
    }
    private async Task SearchTasks(ChangeEventArgs e)
    {
        searchTerm = e.Value?.ToString() ?? "";
        currentPage = 1;
        await LoadEmployees();
    }
    
}
